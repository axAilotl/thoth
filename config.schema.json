{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "thoth.config",
  "type": "object",
  "properties": {
    "llm": {
      "type": "object",
      "properties": {
        "providers": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "api_key_env": { "type": "string" },
                "base_url": { "type": ["string", "null"] },
                "has_vision": { "type": "boolean" },
                "models": {
                  "type": "object",
                  "patternProperties": {
                    "^[a-zA-Z0-9_-]+$": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "prompt": { "type": "string" },
                        "max_tokens": { "type": "integer" },
                        "temperature": { "type": "number" }
                      },
                      "required": ["id"],
                      "additionalProperties": false
                    }
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "tasks": {
          "type": "object",
          "properties": {
            "transcript": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "retry_interval_hours": { "type": "number", "minimum": 0 },
                "fallback": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "provider": { "type": "string" },
                      "model": { "type": "string" }
                    },
                    "required": ["provider"],
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            },
            "translation": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "fallback": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "provider": { "type": "string" },
                      "model": { "type": "string" }
                    },
                    "required": ["provider"],
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            },
            "archivist": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "fallback": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "provider": { "type": "string" },
                      "model": { "type": "string" }
                    },
                    "required": ["provider"],
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "prompts": {
          "type": "object",
          "properties": {
            "translation": {
              "type": "object",
              "properties": {
                "system": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": true
    },
    "processing": {
      "type": "object",
      "additionalProperties": true
    },
    "downloads": {
      "type": "object",
      "additionalProperties": true
    },
    "database": {
      "type": "object",
      "properties": {
        "path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "youtube": {
      "type": "object",
      "additionalProperties": true
    },
    "whisper": {
      "type": "object",
      "additionalProperties": true
    },
    "deepgram": {
      "type": "object",
      "additionalProperties": true
    },
    "ntfy": {
      "type": "object",
      "additionalProperties": true
    },
    "files": {
      "type": "object",
      "additionalProperties": true
    },
    "paths": {
      "type": "object",
      "properties": {
        "vault_dir": { "type": "string" },
        "raw_dir": { "type": "string" },
        "library_dir": { "type": "string" },
        "wiki_dir": { "type": "string" },
        "archivist_topics_file": { "type": "string" },
        "cache_dir": { "type": "string" },
        "images_dir": { "type": "string" },
        "videos_dir": { "type": "string" },
        "media_dir": { "type": "string" },
        "system_dir": { "type": "string" },
        "digests_dir": { "type": "string" },
        "bookmarks_file": { "type": "string" },
        "cookies_file": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sources": {
      "type": "object",
      "properties": {
        "arxiv": {
          "type": "object",
          "properties": {
            "source": { "type": "string", "enum": ["api", "rss"] },
            "feed_format": { "type": "string", "enum": ["rss", "atom"] },
            "topics": {
              "type": "array",
              "items": { "type": "string" }
            },
            "categories": {
              "type": "array",
              "items": { "type": "string" }
            },
            "limit": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "github": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "username": { "type": "string" },
            "token": { "type": "string" },
            "limit": { "type": "integer", "minimum": 1 },
            "resume": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "huggingface": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "username": { "type": "string" },
            "token": { "type": "string" },
            "limit": { "type": "integer", "minimum": 1 },
            "resume": { "type": "boolean" },
            "include_models": { "type": "boolean" },
            "include_datasets": { "type": "boolean" },
            "include_spaces": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "web_clipper": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "note_dirs": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "attachment_dirs": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "note_extensions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "attachment_extensions": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "x_api": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "client_id": { "type": "string" },
            "client_secret_env": { "type": "string" },
            "redirect_uri": { "type": "string" },
            "scopes": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "automation": {
      "type": "object",
      "properties": {
        "social_sync": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "interval_hours": { "type": "number", "minimum": 5 },
            "run_on_startup": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "x_api_sync": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "interval_hours": { "type": "number", "minimum": 5 },
            "run_on_startup": { "type": "boolean" },
            "max_results": { "type": "integer", "minimum": 1, "maximum": 100 },
            "max_pages": { "type": ["integer", "null"], "minimum": 1 },
            "resume_from_checkpoint": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
